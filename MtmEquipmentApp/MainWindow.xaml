<Window x:Class="MtmEquipmentApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MtmEquipmentApp"
        mc:Ignorable="d"
        Title="Учет оборудования" Height="800" Width="1200">
    <Grid>
        <!-- Боковая панель с кнопками для навигации -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1F2937" Grid.Column="0">
            <StackPanel>
                <Button Content="Оборудование"
                        Height="60"
                        FontSize="18"
                        Foreground="White"
                        Background="#374151"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="EquipmentPage" />

                <Button Content="Подразделения"
                        Height="60"
                        FontSize="18"
                        Foreground="White"
                        Background="#374151"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="DepartmentPage" />

                <Button Content="Пользователи"
                        Height="60"
                        FontSize="18"
                        Foreground="White"
                        Background="#374151"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="UserPage" />

                <Button Content="Инспекции"
                        Height="60"
                        FontSize="18"
                        Foreground="White"
                        Background="#374151"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="InspectionPage" />
            </StackPanel>
        </Border>

        <!-- Контент, где будут отображаться страницы -->
        <Frame Grid.Column="1" Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>

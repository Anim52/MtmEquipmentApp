<UserControl x:Class="MtmEquipmentApp.Views.Pages.DepartmentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MtmEquipmentApp.Views.Pages"
             xmlns:viewModels="clr-namespace:MtmEquipmentApp.ViewModel.Departments"
             Height="450" Width="800">

    <UserControl.DataContext>
        <viewModels:DepartmentPageViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Button Content="Добавить подразделение"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Command="{Binding AddDepartment}" />

        <DataGrid ItemsSource="{Binding Departments}"
                  SelectedItem="{Binding SelectedDepartment}"
                  AutoGenerateColumns="False"
                  Margin="0,60,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название"
                                    Binding="{Binding Name}" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Редактировать"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Command="{Binding EditDepartment}"
                Margin="0,0,100,20" />

        <Button Content="Удалить"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Command="{Binding DeleteDepartment}"
                Margin="0,0,20,20" />
    </Grid>
</UserControl>

<Window x:Class="MtmEquipmentApp.Views.Windows.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MtmEquipmentApp.Views.Windows"
       xmlns:viewModels="clr-namespace:MtmEquipmentApp.ViewModel.Users"
        Title="Редактирование пользователя" Height="400" Width="400">

    <Window.DataContext>
        <viewModels:UserEditViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <TextBlock Text="Имя пользователя"
                   VerticalAlignment="Top" FontSize="16" />

        <TextBox Text="{Binding FullName}"
                 VerticalAlignment="Top"
                 Margin="0,40,0,0"
                 Height="30" />

        <TextBlock Text="Логин"
                   VerticalAlignment="Top" FontSize="16" Margin="0,80,0,0"/>

        <TextBox Text="{Binding Login}"
                 VerticalAlignment="Top"
                 Margin="0,120,0,0"
                 Height="30" />

        <TextBlock Text="Роль"
                   VerticalAlignment="Top" FontSize="16" Margin="0,160,0,0"/>

        <ComboBox ItemsSource="{Binding Roles}"
                  SelectedItem="{Binding Role}"
                  VerticalAlignment="Top"
                  Margin="0,200,0,0"
                  Height="30" />

        <Button Content="Сохранить"
                Command="{Binding Save}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="0,0,50,20" />

        <Button Content="Отмена"
                Command="{Binding Cancel}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Left"
                Margin="50,0,0,20" />
    </Grid>
</Window>

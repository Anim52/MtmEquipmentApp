<Window x:Class="MtmEquipmentApp.Views.Windows.DepartmentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MtmEquipmentApp.Views.Windows"
        xmlns:viewModels="clr-namespace:MtmEquipmentApp.ViewModel.Departments"
        Title="Редактирование подразделения" Height="250" Width="400">

    <Window.DataContext>
        <viewModels:DepartmentEditViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <TextBlock Text="Название подразделения"
                   VerticalAlignment="Top" FontSize="16" />

        <TextBox Text="{Binding Name}"
                 VerticalAlignment="Top"
                 Margin="0,40,0,0"
                 Height="30" />

        <Button Content="Сохранить"
                Command="{Binding Save}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="0,0,50,20" />

        <Button Content="Отмена"
                Command="{Binding Cancel}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Left"
                Margin="50,0,0,20" />
    </Grid>
</Window>

<Window x:Class="MtmEquipmentApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MtmEquipmentApp.Views"
        mc:Ignorable="d"
        Title="Авторизация"
        Height="520"
        Width="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Grid>
        <Border CornerRadius="22"
                Background="#F4F7FB"
                BorderBrush="#D9E2EC"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- Левая часть -->
                <Grid Background="#1E293B">
                    <Grid.Resources>
                        <LinearGradientBrush x:Key="PanelGradient" StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0F172A" Offset="0"/>
                            <GradientStop Color="#1D4ED8" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Resources>

                    <Border Background="{StaticResource PanelGradient}"
                            CornerRadius="22,0,0,22">
                        <Grid Margin="40">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="MTM Equipment"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Система учёта и контроля оборудования"
                                           FontSize="18"
                                           Foreground="#DCE7F7"
                                           Margin="0,0,0,28"/>

                                <Border Background="#FFFFFF18"
                                        CornerRadius="18"
                                        Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="Возможности системы"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="Black"
                                                   Margin="0,0,0,16"/>

                                        <TextBlock Text="• учёт оборудования"
                                                   FontSize="15"
                                                   Foreground="Black"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="• журнал инспекций"
                                                   FontSize="15"
                                                   Foreground="Black"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="• контроль дефектов"
                                                   FontSize="15"
                                                   Foreground="Black"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="• разграничение ролей"
                                                   FontSize="15"
                                                   Foreground="Black"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Правая часть -->
                <Grid Grid.Column="1" Margin="48">
                    <Border Background="White"
                            CornerRadius="20"
                            Padding="24"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Вход в систему"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#1F2937"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="Введите логин и пароль для продолжения"
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       Margin="0,0,0,26"/>

                            <TextBlock Text="Логин"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"
                                       Margin="0,0,0,8"/>

                            <Border Background="#F9FAFB"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Margin="0,0,0,18">
                                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="15"
                                         Padding="14"
                                         BorderThickness="0"
                                         Background="Transparent"/>
                            </Border>

                            <TextBlock Text="Пароль"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"
                                       Margin="0,0,0,8"/>

                            <Border Background="#F9FAFB"
                                    BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Margin="0,0,0,12">
                                <PasswordBox x:Name="PasswordInput"
                                             FontSize="15"
                                             Padding="14"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             PasswordChanged="PasswordInput_PasswordChanged"/>
                            </Border>

                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#DC2626"
                                       FontSize="13"
                                       Margin="0,0,0,18"/>

                            <Button Content="Войти"
        Height="48"
        FontSize="15"
        FontWeight="SemiBold"
        Foreground="White"
        Background="#2563EB"
        BorderBrush="Transparent"
        Cursor="Hand"
        Command="{Binding LoginUserCommand}"
        CommandParameter="{Binding ElementName=PasswordInput, Path=Password}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                    CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock Text="Демо-вход: admin / admin"
                                       Foreground="#6B7280"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,16,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Кнопка закрытия -->
                <Button Content="✕"
                        Width="34"
                        Height="34"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,14,14,0"
                        Background="#FFFFFF22"
                        Foreground="Black"
                        BorderBrush="Transparent"
                        Cursor="Hand"
                        Click="Close_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="17">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
